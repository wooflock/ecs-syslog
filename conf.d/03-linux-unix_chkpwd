# this is the input to ssh. All input goes through here and selected 
# to go to some other pipeline.

input { pipeline { address => "linux-unix-chkpwd" } }

# events in ecs that we place here relevant on this level.
# [error][message]
#        [code]
#        [type]
#        [stack_trace]
#        [id]
#
# [event]
#        [action]
#        [category]
#        [code]
#        [created]  # we place @timestamp here
#        [dataset]  
#        [hash] # hash of the log to demonstrate integrity
#        [kind] # alert, asset, enrichment, event, metric, state, pipeline_error, signal
#        [module]
#        [outcome] # failure, success, unknown
#        [reason]
#        [reference] # link to where we find more data.. Misp event link etc.
#        [sequence]
#        [severity] # you can copy log.syslog.severity.code here if not a special one exists
#        [type] # access, admin, allowed, change, connection, creation, deletion, denied, device, end, error, group, indicator (array)
#
# [host]

filter {
  grok {
    id => "grok_unix_chkpwd_parse"
    patterns_dir => ["/etc/logstash/patterns/pipes"]
    match => {
      "syslog_message" => "%{APP_UNIX_CHKPWD}"
    }
    tag_on_failure => ["_grokfail:pipeline=linux-unix-chkpwd:filter=grok_unix_chkpwd_parse"]
  }

  # adding the higher level event fields
  mutate {
    add_field => {
      "[event][module]" => "linux"
      "[event][dataset]" => "linux.unix_chkpwd"
      "[service][type]" => "unix_chkpwd"
      "[service][name]" => "unix_chkpwd"
    }
  }

  if [syslog_message] ~ /^check pass; user unknown/ {
    mutate {
      add_field => {
        "[event][action]" => "unix_chkpwd_user_unknown"
        "[event][outcome]" => "failure"
      }
    }
    # we use ruby to set array items since this works on most logstashversions
    ruby {
      code => '
        event.set("[event][type]", ["denied"])
        event.set("[event][category]", ["authentication"])
      '
    }
  } else if [syslog_message] =~ /^password check failed for user/ {
    mutate {
      add_field => {
        "[event][action]" => "unix_chkpwd_password_check_failed"
        "[event][outcome]" => "failure"
      }
    }
    ruby {
      code => '
        event.set("[event][type]", ["denied","user"])
        event.set("[event][category]", ["authentication"])
      '
    }
  }
}

output {
  pipeline { send_to => output }
}

